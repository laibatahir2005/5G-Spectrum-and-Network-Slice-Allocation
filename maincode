def extract_counts_sampler_v2(result, pub_index=0):
    """
    Robust SamplerV2 counts extractor.
    Works for measure_all() register name 'meas'.
    Does not force get_counts(0), because for non-parametric circuits
    get_counts() is safer.
    """
    pub_result = result[pub_index]
    data = pub_result.data

    # Most common when using measure_all()
    if hasattr(data, "meas"):
        try:
            return data.meas.get_counts()
        except TypeError:
            return data.meas.get_counts(0)

    # If classical register has another name
    for reg_name in dir(data):
        reg = getattr(data, reg_name)
        if hasattr(reg, "get_counts"):
            try:
                return reg.get_counts()
            except TypeError:
                return reg.get_counts(0)

    raise RuntimeError("Could not extract counts from SamplerV2 result.")


