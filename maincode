def extended_sampling_metrics(counts, label):
    total = sum(counts.values())

    feasible_shots = 0
    optimal_raw_shots = 0
    optimal_repaired_shots = 0

    raw_cost_sum = 0.0
    repaired_cost_sum = 0.0

    best_raw_cost = None
    best_repaired_cost = None
    best_raw_bitstring = None
    best_repaired_bitstring = None

    for bitstring, count in counts.items():
        bits = key_to_bits(bitstring)

        raw_assign = bits_to_assignment(bits)
        repaired_assign = repair_bits(bits)

        raw_cost = qubo_cost(bits)
        repaired_cost = assignment_metrics(repaired_assign)["cost"]

        raw_cost_sum += raw_cost * count
        repaired_cost_sum += repaired_cost * count

        if raw_assign is not None:
            feasible_shots += count

            if raw_assign == OPTIMAL_ASSIGNMENT:
                optimal_raw_shots += count

        if repaired_assign == OPTIMAL_ASSIGNMENT:
            optimal_repaired_shots += count

        if best_raw_cost is None or raw_cost < best_raw_cost:
            best_raw_cost = raw_cost
            best_raw_bitstring = bitstring

        if best_repaired_cost is None or repaired_cost < best_repaired_cost:
            best_repaired_cost = repaired_cost
            best_repaired_bitstring = bitstring

    return {
        "method": label,
        "shots": total,
        "unique_bitstrings": len(counts),
        "feasible_probability": feasible_shots / total,
        "optimal_raw_probability": optimal_raw_shots / total,
        "optimal_repaired_probability": optimal_repaired_shots / total,
        "mean_raw_cost": raw_cost_sum / total,
        "mean_repaired_cost": repaired_cost_sum / total,
        "best_raw_cost": best_raw_cost,
        "best_repaired_cost": best_repaired_cost,
        "best_raw_bitstring": best_raw_bitstring,
        "best_repaired_bitstring": best_repaired_bitstring,
        "approximation_gap_repaired": best_repaired_cost - OPTIMAL_COST,
    }


