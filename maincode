# ============================================================
# 2. DEFINE 5G NETWORK PROBLEM
# ============================================================

# 5 users and 3 resource blocks
N_USERS = 5
N_BLOCKS = 3
N_QUBITS = N_USERS * N_BLOCKS

def var_index(user, block):
    return user * N_BLOCKS + block

def inv_var_index(a):
    return a // N_BLOCKS, a % N_BLOCKS

def var_label(a):
    i, k = inv_var_index(a)
    return f"U{i+1}R{k+1}"

# Utility matrix u[i,k]
# Larger utility = better assignment
utility = np.array([
    [9.0, 4.0, 7.0],
    [8.0, 6.0, 5.0],
    [5.0, 9.0, 6.0],
    [7.0, 5.0, 8.0],
    [6.0, 8.0, 4.0],
])

# Target load for each resource block
target_load = np.array([2, 2, 1])

# Interference edges: user_i, user_j, weight
interference_edges = [
    (0, 1, 1.00),
    (0, 2, 0.80),
    (1, 2, 1.20),
    (1, 3, 0.60),
    (2, 4, 1.00),
    (3, 4, 0.70),
]

# Penalty weights
ALPHA_UTILITY = 1.0
A_ASSIGN = 9.0
B_BALANCE = 1.5
D_INTERFERENCE = 8.0

# ============================================================
# 3. BUILD QUBO
# Cost:
# C(x) =
# - utility reward
# + assignment penalty
# + load-balance penalty
# + interference penalty
# ============================================================

constant = 0.0
linear = np.zeros(N_QUBITS)
quadratic = np.zeros((N_QUBITS, N_QUBITS))

def add_linear(a, coeff):
    linear[a] += coeff

def add_quadratic(a, b, coeff):
    if a == b:
        linear[a] += coeff
    else:
        i, j = sorted((a, b))
        quadratic[i, j] += coeff

# Utility term: -sum u[i,k] x[i,k]
for i in range(N_USERS):
    for k in range(N_BLOCKS):
        a = var_index(i, k)
        add_linear(a, -ALPHA_UTILITY * utility[i, k])

# Assignment penalty: A(1 - sum_k x[i,k])^2
for i in range(N_USERS):
    constant += A_ASSIGN

    for k in range(N_BLOCKS):
        a = var_index(i, k)
        add_linear(a, -A_ASSIGN)

    for k1 in range(N_BLOCKS):
        for k2 in range(k1 + 1, N_BLOCKS):
            a = var_index(i, k1)
            b = var_index(i, k2)
            add_quadratic(a, b, 2 * A_ASSIGN)

# Balance penalty: B(sum_i x[i,k] - Ck)^2
for k in range(N_BLOCKS):
    Ck = target_load[k]
    constant += B_BALANCE * Ck**2

    for i in range(N_USERS):
        a = var_index(i, k)
        add_linear(a, B_BALANCE * (1 - 2 * Ck))

    for i in range(N_USERS):
        for j in range(i + 1, N_USERS):
            a = var_index(i, k)
            b = var_index(j, k)
            add_quadratic(a, b, 2 * B_BALANCE)
# Interference penalty: D w_ij x[i,k]x[j,k]
for i, j, w in interference_edges:
    for k in range(N_BLOCKS):
        a = var_index(i, k)
        b = var_index(j, k)
        add_quadratic(a, b, D_INTERFERENCE * w)

def qubo_cost(bits):
    bits = np.array(bits, dtype=int)
    cost = constant + np.dot(linear, bits)

    for i in range(N_QUBITS):
        for j in range(i + 1, N_QUBITS):
            cost += quadratic[i, j] * bits[i] * bits[j]

    return float(cost)

# QUBO matrix for plotting
Q_display = np.zeros((N_QUBITS, N_QUBITS))
np.fill_diagonal(Q_display, linear)
for i in range(N_QUBITS):
    for j in range(i + 1, N_QUBITS):
        Q_display[i, j] = quadratic[i, j]
        Q_display[j, i] = quadratic[i, j]

# ============================================================
# 4. DECODING AND METRICS
# ============================================================

def assignment_to_bits(assign):
    bits = np.zeros(N_QUBITS, dtype=int)
    for i, k in enumerate(assign):
        bits[var_index(i, k)] = 1
    return bits

def bits_to_assignment(bits):
    bits = np.array(bits, dtype=int)
    assign = []

    for i in range(N_USERS):
        row = bits[i*N_BLOCKS:(i+1)*N_BLOCKS]
        chosen = np.where(row == 1)[0]

        if len(chosen) != 1:
            return None

        assign.append(int(chosen[0]))

    return tuple(assign)

def repair_bits(bits):
    bits = np.array(bits, dtype=int)

    assign = [-1] * N_USERS
    loads = np.zeros(N_BLOCKS, dtype=int)

    # keep valid one-hot rows
    for i in range(N_USERS):
        row = bits[i*N_BLOCKS:(i+1)*N_BLOCKS]
        chosen = np.where(row == 1)[0]

        if len(chosen) == 1:
            k = int(chosen[0])
            assign[i] = k
            loads[k] += 1

    # repair invalid rows
    for i in range(N_USERS):
        if assign[i] != -1:
            continue

        best_k = None
        best_score = 1e18

        for k in range(N_BLOCKS):
            score = -utility[i, k]

            before = (loads[k] - target_load[k])**2
            after = (loads[k] + 1 - target_load[k])**2
            score += B_BALANCE * (after - before)

            for a, b, w in interference_edges:
                if a == i and assign[b] == k:
                    score += D_INTERFERENCE * w
                if b == i and assign[a] == k:
                    score += D_INTERFERENCE * w

            if score < best_score:
                best_score = score
                best_k = k

        assign[i] = best_k
        loads[best_k] += 1

    return tuple(assign)

def assignment_metrics(assign):
    bits = assignment_to_bits(assign)

    total_utility = sum(utility[i, assign[i]] for i in range(N_USERS))

    conflicts = 0
    weighted_conflict = 0.0

    for i, j, w in interference_edges:
        if assign[i] == assign[j]:
            conflicts += 1
            weighted_conflict += w

    loads = np.zeros(N_BLOCKS, dtype=int)
    for k in assign:
        loads[k] += 1

    return {
        "assignment": assign,
        "utility": float(total_utility),
        "conflicts": conflicts,
        "weighted_conflict": float(weighted_conflict),
        "loads": tuple(loads.tolist()),
        "cost": qubo_cost(bits),
    }
def key_to_bits(key):
    # Qiskit count key is reversed compared to qubit index order
    return np.array([int(b) for b in key[::-1]], dtype=int)

def bits_to_key(bits):
    return "".join(str(int(bits[i])) for i in reversed(range(len(bits))))

# ============================================================
# 5. CLASSICAL BASELINES
# ============================================================

def brute_force_exact():
    best = None

    for assign in itertools.product(range(N_BLOCKS), repeat=N_USERS):
        metrics = assignment_metrics(assign)

        if best is None or metrics["cost"] < best["cost"]:
            best = metrics

    return best

def greedy_baseline():
    assign = [-1] * N_USERS
    loads = np.zeros(N_BLOCKS, dtype=int)

    user_order = np.argsort(-utility.max(axis=1))

    for i in user_order:
        best_k = None
        best_score = 1e18

        for k in range(N_BLOCKS):
            score = -utility[i, k]

            before = (loads[k] - target_load[k])**2
            after = (loads[k] + 1 - target_load[k])**2
            score += B_BALANCE * (after - before)

            for a, b, w in interference_edges:
                if a == i and assign[b] == k:
                    score += D_INTERFERENCE * w
                if b == i and assign[a] == k:
                    score += D_INTERFERENCE * w

            if score < best_score:
                best_score = score
                best_k = k

        assign[i] = best_k
        loads[best_k] += 1

    return assignment_metrics(tuple(assign))

def random_baseline(samples=5000):
    best = None

    for _ in range(samples):
        assign = tuple(rng.integers(0, N_BLOCKS, size=N_USERS))
        metrics = assignment_metrics(assign)

        if best is None or metrics["cost"] < best["cost"]:
            best = metrics

    return best

brute_best = brute_force_exact()
greedy_best = greedy_baseline()
random_best = random_baseline()

