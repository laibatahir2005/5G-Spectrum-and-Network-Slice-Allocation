# ============================================================
# 6. QUBO TO ISING
# x = (1 - Z)/2
# H_C = sum h_i Z_i + sum J_ij Z_i Z_j
# ============================================================

ising_constant = constant
z_linear = np.zeros(N_QUBITS)
zz_couplings = np.zeros((N_QUBITS, N_QUBITS))

# Linear QUBO terms
for i in range(N_QUBITS):
    h = linear[i]

    ising_constant += h / 2
    z_linear[i] += -h / 2

# Quadratic QUBO terms
for i in range(N_QUBITS):
    for j in range(i + 1, N_QUBITS):
        q = quadratic[i, j]

        if abs(q) > 1e-12:
            ising_constant += q / 4
            z_linear[i] += -q / 4
            z_linear[j] += -q / 4
            zz_couplings[i, j] += q / 4


print("Number of qubits:", N_QUBITS)
print("Ising constant:", ising_constant)
print("Number of ZZ couplings:", np.count_nonzero(zz_couplings))


# ============================================================
# 7. BUILD QAOA CIRCUIT
# ============================================================

def build_qaoa_circuit(gammas, betas, measure=False):
    p = len(gammas)
    qc = QuantumCircuit(N_QUBITS)

    # Initial state |+>^n
    qc.h(range(N_QUBITS))

    for layer in range(p):
        gamma = float(gammas[layer])
        beta = float(betas[layer])

        # Cost layer: Z rotations
        for q in range(N_QUBITS):
            h = z_linear[q]
            if abs(h) > 1e-12:
                qc.rz(2 * gamma * h, q)

        # Cost layer: ZZ rotations using CX-RZ-CX
        for i in range(N_QUBITS):
            for j in range(i + 1, N_QUBITS):
                J = zz_couplings[i, j]

                if abs(J) > 1e-12:
                    qc.cx(i, j)
                    qc.rz(2 * gamma * J, j)
                    qc.cx(i, j)

        # Mixer layer: RX gates
        for q in range(N_QUBITS):
            qc.rx(2 * beta, q)

    if measure:
        qc.measure_all()

    return qc


    # ============================================================
# 8. QAOA OPTIMIZATION USING STATEVECTOR
# ============================================================

def index_to_bits(index, n=N_QUBITS):
    return np.array([(index >> q) & 1 for q in range(n)], dtype=int)

# Precompute all QUBO costs
all_costs = np.zeros(2**N_QUBITS)

for idx in range(2**N_QUBITS):
    bits = index_to_bits(idx)
    all_costs[idx] = qubo_cost(bits)

def qaoa_expectation(theta, p):
    gammas = theta[:p]
    betas = theta[p:]

    qc = build_qaoa_circuit(gammas, betas, measure=False)
    sv = Statevector.from_instruction(qc)

    probs = np.abs(sv.data)**2
    return float(np.dot(probs, all_costs))

def optimize_qaoa(p):
    best_result = None
    best_history = None

    for start in range(N_STARTS):
        history = []

        theta0 = np.concatenate([
            rng.uniform(-np.pi, np.pi, size=p),
            rng.uniform(0, np.pi, size=p)
        ])

        def objective(theta):
            value = qaoa_expectation(theta, p)
            history.append(value)
            return value

        result = minimize(
            objective,
            theta0,
            method="COBYLA",
            options={"maxiter": MAXITER, "rhobeg": 0.8}
        )

        print(f"p={p}, start={start+1}, expectation={result.fun:.4f}")

        if best_result is None or result.fun < best_result.fun:
            best_result = result
            best_history = history

    return best_result, best_history

qaoa_results = {}

for p in QAOA_DEPTHS:
    print("\nOptimizing QAOA p =", p)
    result, history = optimize_qaoa(p)

    qaoa_results[p] = {
        "result": result,
        "theta": result.x,
        "expectation": result.fun,
        "history": history,
    }

best_p = min(qaoa_results, key=lambda p: qaoa_results[p]["expectation"])
best_theta = qaoa_results[best_p]["theta"]

print("\nBest p:", best_p)
print("Best expectation:", qaoa_results[best_p]["expectation"])
print("Best theta:", best_theta)


# ============================================================
# 9. FINAL QAOA CIRCUIT
# ============================================================

gammas_opt = best_theta[:best_p]
betas_opt = best_theta[best_p:]

final_circuit = build_qaoa_circuit(gammas_opt, betas_opt, measure=True)

print(final_circuit)
