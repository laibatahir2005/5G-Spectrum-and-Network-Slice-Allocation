def plot_qmatrix_correlation_graph(top_n=25):
    """
    Plot strongest QUBO correlations/couplings.
    
    Node  = binary allocation variable, e.g. U1R1
    Edge  = QUBO coupling between two variables
    Weight = penalty strength
    """

    coupling_df = qmatrix_top_couplings(top_n=top_n)

    G = nx.Graph()

    for _, row in coupling_df.iterrows():

        a = row["label_i"]
        b = row["label_j"]
        weight = float(row["QUBO_coupling"])

        G.add_node(a)
        G.add_node(b)
        G.add_edge(a, b, weight=weight)

    pos = nx.spring_layout(G, seed=SEED)

    edge_weights = [G[u][v]["weight"] for u, v in G.edges()]
    max_w = max(edge_weights)

    widths = [1.0 + 4.0 * (w / max_w) for w in edge_weights]

    plt.figure(figsize=(11, 7))

    nx.draw_networkx_nodes(
        G,
        pos,
        node_size=900,
        node_color="lightgreen",
        edgecolors="black"
    )

    nx.draw_networkx_edges(
        G,
        pos,
        width=widths,
        alpha=0.75
    )

    nx.draw_networkx_labels(
        G,
        pos,
        font_size=8,
        font_weight="bold"
    )

    edge_labels = {
        (u, v): f"{G[u][v]['weight']:.1f}"
        for u, v in G.edges()
    }

    nx.draw_networkx_edge_labels(
        G,
        pos,
        edge_labels=edge_labels,
        font_size=7
    )

    plt.title(
        "Q-SliceNet Q-Matrix Correlation Graph\n"
        "Strong edges = strong QUBO penalties between allocation decisions"
    )

    plt.axis("off")
    plt.tight_layout()

    plt.savefig(
        OUTDIR / "qmatrix_correlation_graph.png",
        dpi=300
    )

    plt.show()


