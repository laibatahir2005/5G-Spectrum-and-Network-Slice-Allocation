def analyze_counts(counts, label, top_n=20):
    total = sum(counts.values())
    rows = []

    for key, count in sorted(counts.items(), key=lambda x: x[1], reverse=True)[:top_n]:
        bits = key_to_bits(key)
        raw_assignment = bits_to_assignment(bits)
        repaired_assignment = repair_bits(bits)
        repaired_metrics = assignment_metrics(repaired_assignment)

        onehot_violations = 0
        for i in range(N_USERS):
            row = bits[i*N_BLOCKS:(i+1)*N_BLOCKS]
            if np.sum(row) != 1:
                onehot_violations += 1

        rows.append({
            "source": label,
            "bitstring": key,
            "count": count,
            "probability": count / total,
            "raw_assignment": raw_assignment,
            "raw_cost": qubo_cost(bits),
            "onehot_violations": onehot_violations,
            "repaired_assignment": repaired_assignment,
            "repaired_cost": repaired_metrics["cost"],
            "repaired_utility": repaired_metrics["utility"],
            "repaired_conflicts": repaired_metrics["conflicts"],
            "repaired_loads": repaired_metrics["loads"],
        })

    return pd.DataFrame(rows)

