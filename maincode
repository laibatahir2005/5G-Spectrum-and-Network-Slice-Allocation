def qmatrix_top_couplings(top_n=30):
    """
    Extract strongest QUBO couplings from the quadratic Q matrix.
    Strong positive coupling means two binary allocation decisions
    are penalized when selected together.
    """

    rows = []

    for i in range(N_QUBITS):
        for j in range(i + 1, N_QUBITS):

            q = quadratic[i, j]

            if abs(q) > 1e-12:

                # If zz_couplings exists, include Ising ZZ coupling
                if "zz_couplings" in globals():
                    zz_value = zz_couplings[i, j]
                else:
                    zz_value = np.nan

                rows.append({
                    "var_i": i,
                    "var_j": j,
                    "label_i": var_label(i),
                    "label_j": var_label(j),
                    "QUBO_coupling": q,
                    "Ising_ZZ_coupling": zz_value,
                    "abs_coupling": abs(q),
                })

    df = pd.DataFrame(rows)

    if len(df) == 0:
        raise ValueError("No QUBO couplings found. Check your quadratic matrix.")

    df = df.sort_values("abs_coupling", ascending=False)

    return df.head(top_n).reset_index(drop=True)


